{
  "ci": {
    "collect": {
      "staticDistDir": "docs/audits",
      "url": ["/dashboard.html"],
      "numberOfRuns": 3,
      "settings": { "preset": "desktop" }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "docs/audits/lighthouse"
    }
  }
}
